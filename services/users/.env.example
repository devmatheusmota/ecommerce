# Users service — DB connection
# PG_HOST=postgres when running in Docker; localhost when running Go locally
PG_HOST=postgres
PG_PORT=5432
PG_USER=ecommerce
PG_PASSWORD=ecommerce_dev
PG_DATABASE=users

# Must match Kong consumer JWT secret (infra/kong/kong.yml.template). Dev: use "dev".
JWT_SECRET=dev
